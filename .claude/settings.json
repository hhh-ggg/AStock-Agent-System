{
  "defaultMode": "default",
  "permissions": {
    "allow": [
      "Bash(git status)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(python --version)",
      "Bash(py --version)",
      "Bash(pip --version)",
      "Bash(pytest *)",
      "Bash(ruff *)",
      "Bash(mypy *)",
      "Bash(docker compose ps)",
      "Bash(docker compose logs *)"
    ],
    "ask": [
      "Bash(pip install *)",
      "Bash(py -m pip install *)",
      "Bash(docker compose up *)",
      "Bash(docker compose down *)",
      "Bash(alembic *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(curl *)",
      "Bash(npm *)"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./secrets/**)",
      "Read(./config/credentials.json)",
      "Bash(git push *)",
      "Bash(rm -rf *)",
      "Bash(del /s *)",
      "Bash(Remove-Item *)",
      "Bash(format *)",
      "Bash(taskkill *)",
      "Bash(Stop-Process *)"
    ]
  }
}
